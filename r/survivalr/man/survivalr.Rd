\arguments{
\item{time, time2, event}{Survival response vectors. \code{time} is also
accepted as exposure time for \code{cipoisson}, a direct \code{survexp}
follow-up vector, and direct \code{survobrien} event time vector.}
\item{time1, start, stop, status}{Named aliases for R-style response
construction. \code{time1} and \code{start} map to the first time column,
\code{stop} maps to \code{time2}, and \code{status} maps to \code{event};
\code{status} is also the direct event-code vector for \code{survobrien}.}
\item{type}{Optional survival response, prediction, \code{survfitKM} curve,
or plotted line type.}
\item{origin}{Optional time origin passed to the Python response constructor.}
\item{value}{Object to test.}
\item{verbose}{Logical flag accepted by \code{is.ratetable}.}
\item{edge}{Lower/upper probability clamp for bounded link helpers
\code{blogit}, \code{bprobit}, \code{bcloglog}, and \code{blog}.}
\item{tolerance}{Near-tie tolerance for \code{aeqSurv} and survival
quantile inversion.}
\item{breaks}{Strictly increasing cut points for \code{tcut}.}
\item{labels}{Optional interval labels for \code{tcut}.}
\item{cut}{Cut points for \code{survSplit}.}
\item{repeated}{Logical flag accepted by \code{Surv2} for repeated events.}
\item{id1}{Query IDs for \code{neardate}.}
\item{id2}{Reference IDs for \code{neardate}, or second subject identifiers
for low-level Cox survival-curve inputs.}
\item{y1, y2}{Query and reference dates or numeric values for \code{neardate}.}
\item{best}{Nearest-date direction, either \code{"after"} or \code{"prior"}.
The bridge also accepts \code{"closest"} as a Python-backed extension.}
\item{nomatch}{Scalar value used when \code{neardate} cannot find a match.}
\item{df}{Optional degrees of freedom for \code{nsk}, \code{ridge},
\code{frailty.*}, and \code{pspline}.}
\item{knots}{Optional interior knot locations for \code{nsk}.}
\item{intercept}{Logical flag controlling whether \code{nsk} includes the
first knot-height column, or whether \code{pspline} includes an intercept.}
\item{b}{Boundary quantile used by the default \code{nsk} boundary knots.}
\item{Boundary.knots}{Boundary knots for \code{nsk} and \code{pspline};
logical values follow the compatibility behavior of \code{survival::nsk}.}
\item{theta}{Fixed penalty parameter for \code{ridge}, \code{frailty.*}, and
\code{pspline}.}
\item{sparse}{Logical flag controlling sparse frailty coding.}
\item{tdf}{Degrees of freedom for Student-t frailty.}
\item{nterm, degree, penalty, combine}{Spline basis and penalty controls for
\code{pspline}.}
\item{tstart, tstop, ctime, cprob, extend, keep}{Direct-vector inputs for
Python-backed \code{finegray} interval expansion. \code{extend} also controls
whether \code{summary.survival_py_survfit} carries estimates beyond the last
observed curve time.}
\item{data1, data2}{Input data frames for delegated \code{tmerge}.}
\item{subcoh, stratum, cohort.size}{Case-cohort design inputs for delegated
\code{cch}.}
\item{qrtol, nmin, dfbeta, taper}{Control values for delegated
\code{aareg}.}
\item{id}{Optional generated row identifier column for \code{survSplit}, or
subject identifiers for \code{survcondense}, \code{survcheck}, timeline
converters, \code{Surv2data}, delegated \code{cch}/\code{tmerge}, and
low-level \code{survfitKM}.}
\item{istate}{Optional initial state vector for \code{survcheck} and
timeline converters.}
\item{istate0}{Initial-state label accepted for \code{survcheck}
compatibility.}
\item{zero}{Origin used when splitting right-censored \code{survSplit}
input.}
\item{censor, single}{Event-censor code and singleton handling for
\code{nostutter}. \code{censor} also controls whether
\code{points.survival_py_survfit} marks censoring rows instead of event rows.}
\item{episode, end, added}{Output column controls for
\code{survSplit} and \code{survcondense}; \code{added} is accepted for R API
compatibility.}
\item{tt, special, order}{Term-object special-term inputs for
\code{untangle.specials}; \code{tt} is also accepted by
\code{attrassign.default}.}
\item{formula}{Formula, formula string, bridged \code{Surv} response, or
bridged fitted Cox model accepted by \code{survival.r_api}.}
\item{data, newdata}{Optional data frames or Python-compatible data objects.}
\item{subset}{Optional row subset.}
\item{na.action}{Missing-data policy, either a string or one of the common
\pkg{stats} NA action functions.}
\item{na.rm}{Logical flag controlling whether missing \code{Surv} rows are
removed before computing survival quantiles.}
\item{group}{Optional group vector for direct \code{survdiff} and
\code{pyears} calls.}
\item{by}{Optional grouping vector or list for aggregating Python-backed Cox
\code{survfit} prediction curves across their \code{data} margin.}
\item{FUN}{Summary function for \code{aggregate.survival_py_survfit};
currently \code{mean} is supported.}
\item{rmean, dosum}{Accepted \code{summary.survival_py_survfit}
compatibility arguments. The tabular bridge summary uses \code{dosum} for
interval event/censor counts when explicit \code{times} are supplied.}
\item{rmap}{Optional rate-table variable mapping for formula
\code{survexp} and \code{pyears} calls delegated to \pkg{survival}.}
\item{expect}{Expected-count scale selector accepted by \code{pyears}.}
\item{method}{Expected-survival method for \code{survexp}, tie method for
\code{coxph.fit} and \code{clogit}, case-cohort method for \code{cch},
penalty selection method for \code{frailty.*} and \code{pspline}, or interval method
for \code{cipoisson}. Direct Python \code{survexp} calls accept
\code{"ederer"}, \code{"hakulinen"}, \code{"conditional"},
\code{"individual.h"}, and \code{"individual.s"}. For \code{yates}, method
selects the direct or SGTT contrast path.}
\item{etype, prefix, count}{Formula \code{finegray} options delegated to
\code{survival::finegray}.}
\item{transform}{Formula \code{survobrien} option delegated to
\code{survival::survobrien}.}
\item{covariate}{Direct numeric covariate vector for Python-backed
\code{survobrien}.}
\item{scores, risk.scores}{Optional direct concordance score vectors or
matrices. Use at most one of these.}
\item{weight, weights}{Optional case weights.}
\item{R}{Rate-table covariate matrix or data frame for
\code{match.ratetable}.}
\item{ratetable}{Optional Python-backed rate table for direct
\code{survexp} calls, or a native R reference table for
\code{match.ratetable}. Omit it in direct \code{survexp} calls to use the
bundled Python US table. Formula calls are delegated to
\code{survival::survexp}.}
\item{times}{Optional \code{rttright} output times or requested
\code{summary.survival_py_survfit} times. Multiple \code{rttright} times
return a numeric matrix with one row per input observation and one column per
time.}
\item{cohort, conditional}{Logical flags selecting the default direct
\code{survexp} method when \code{method} is omitted.}
\item{ties, adjust}{Logical options for \code{royston}; \code{ties}
controls tied linear-predictor normal scores and \code{adjust} applies the
Royston-Sauerbrei small-sample adjustment.}
\item{renorm}{Logical flag controlling \code{rttright} weight normalization.}
\item{layout, connect}{State layout specification and square transition
matrix for \code{statefig}.}
\item{margin, box, cex, col, lwd, lty, bcol, acol, alwd, alty}{Plot
style arguments accepted for \code{statefig} compatibility.}
\item{pch, log, xscale, yscale, xlim, ylim, xmax, xlab, ylab, xaxs,
mark.time, cumhaz, fun}{Plotting controls for Python-backed
\code{survfit} curves. The bridge supports common step-curve drawing and
basic survival/cumulative-hazard transformations.}
\item{na.group}{Logical flag controlling whether missing \code{strata}
values form an explicit \code{NA} level.}
\item{shortlabel}{Logical flag controlling whether \code{strata} omits
variable-name prefixes from level labels.}
\item{sep}{Separator used when constructing multi-variable \code{strata}
labels.}
\item{cluster}{Optional cluster labels for robust variance where supported.}
\item{strata}{Optional strata labels for \code{coxph.fit},
\code{concordancefit}, \code{survConcordance.fit}, and direct
\code{survobrien}.}
\item{ymin, ymax, timewt, influence, ranks, reverse, keepstrata, std.err}{
Low-level \code{concordancefit} controls matching the R \pkg{survival}
entry point.}
\item{fit, object}{Bridged model or result object.}
\item{model}{Logical flag accepted for R formula compatibility where
supported.}
\item{x, y}{Logical flags accepted for R formula compatibility where
supported. \code{x} is also used as a data vector for helpers such as
\code{tcut}, \code{nsk}, \code{dsurvreg}, \code{concordancefit}, and
\code{survConcordance.fit}, and as the covariate matrix for
\code{coxph.fit}; \code{y} is also accepted as a \code{Surv} response for
\code{coxph.fit}, \code{concordancefit}, and \code{survConcordance.fit}. In
Python, \code{x} is the input vector for bounded link helper transforms.}
\item{age, year, sex}{Direct-vector rate-table inputs for Python-backed
\code{survexp}.}
\item{censored}{Logical flag controlling whether \code{summary.survival_py_survfit}
includes censor-only rows when no explicit \code{times} vector is supplied.}
\item{collapse, weighted, extra}{Logical flags for \code{pseudo} and
\code{residuals.survival_py_survfit}. The residuals bridge supports
right-censored and counting-process Kaplan-Meier \code{survfit} objects with
retained model frames.}
\item{data.frame}{Logical flag controlling whether \code{pseudo} returns a
long data frame instead of a matrix.}
\item{q, p, n}{Quantiles, probabilities, or draw count for the
\code{survreg} distribution helpers; \code{p} is the confidence level for
\code{cipoisson} and the survival probabilities for
\code{survfit_confint}.}
\item{probs}{Survival quantile probabilities.}
\item{se}{Standard-error vector for \code{survfit_confint}.}
\item{logse}{Logical flag indicating whether \code{se} is already on the
log-survival scale for \code{survfit_confint}.}
\item{conf.type}{Confidence interval transform for \code{survfit_confint}
and \code{survfitKM}.}
\item{conf.int}{Confidence level for \code{survfit_confint}, or logical flag
controlling confidence bounds in \code{quantile.survival_py_survfit}.}
\item{selow}{Optional lower-side standard-error vector for asymmetric
\code{survfit_confint} bounds.}
\item{ulimit}{Logical flag controlling upper-bound clipping in
\code{survfit_confint}.}
\item{mean}{Location parameter for the \code{survreg} distribution helpers.}
\item{distribution}{Distribution name for \code{frailty} or the
\code{survreg} distribution helpers.}
\item{parms}{Optional distribution parameters. Used for the Student-t
\code{survreg} helper distribution; ignored by the other built-in helper
distributions to match R.}
\item{eps, toler.chol, iter.max, toler.inf, outer.max, timefix}{Control
options passed through \code{coxph.control}. \code{eps} is also the
convergence tolerance used when \code{ridge}, \code{frailty.*}, or
\code{pspline} searches for a penalty matching \code{df}.}
\item{maxiter, rel.tolerance, debug}{Control options passed through
\code{survreg.control}.}
\item{dlist}{Distribution-list object for \code{survregDtest}.}
\item{row.names, optional, make.names}{Standard \code{as.data.frame}
arguments.}
\item{digits}{Number of significant digits used by \code{print.concordance}.}
\item{quote}{Logical flag controlling whether printed survival-time labels are
quoted.}
\item{i, j, name, exact, drop}{Row and column subset controls for native
\code{Surv} and \code{Surv2} objects, plus list-field extraction controls for
Python-backed \code{survfit} objects.}
\item{centered}{Logical flag for centered baseline hazards.}
\item{detail}{Logical flag requesting detailed \code{brier} output.}
\item{efron}{Logical flag selecting Efron-compatible \code{brier} baseline
survival when the fitted Cox model used Efron ties.}
\item{term}{Model term for \code{yates}.}
\item{population, levels}{Population weighting and level controls for
\code{yates}.}
\item{predict, options, nsim}{Prediction scale, optional prediction settings,
and simulation count for \code{yates}.}
\item{complete}{Logical flag requesting the full variance matrix where the
Python fit exposes extra parameters such as estimated survreg scale terms.}
\item{offset, init, control, rownames, resid, nocenter}{Low-level
\code{coxph.fit}, \code{agexact.fit}, \code{agreg.fit}, and delegated
\code{survreg.fit}/\code{survpenal.fit} optimizer inputs matching the R
\pkg{survival} entry points. \code{offset} is also accepted by
\code{statefig}.}
\item{controlvals, dist, nstrat, pcols, pattr, assign}{Low-level delegated
\code{survreg.fit} and \code{survpenal.fit} inputs.}
\item{varmat, wt, risk, newrisk, position, oldid, x2, risk2, strata2,
survtype, vartype, unlist}{Low-level delegated Cox survival-curve inputs.}
\item{var}{Variance matrix for \code{coxph.wtest}.}
\item{parm}{Optional coefficient names or 1-based coefficient indices.}
\item{level}{Confidence level for coefficient intervals.}
\item{se.fit}{Logical flag requesting standard errors when supported.}
\item{stype, ctype, conf.lower, start.time, entry, time0, robust}{Low-level
\code{survfitKM} controls matching the R \pkg{survival} entry point where
supported.}
\item{scale}{Scale parameter for \code{survreg} distribution helpers, the
standard \code{extractAIC} scale argument, divisor for survival quantile and
\code{summary.survival_py_survfit} times, or a logical flag controlling
whether \code{ridge} scales the penalty
by column variance.}
\item{k}{Penalty multiplier for \code{extractAIC}, or observed Poisson event
count for \code{cipoisson}.}
\item{test}{Test name for bridged model analysis of variance, \code{aareg}
test selector, or contrast test selector for \code{yates}.}
\item{...}{Additional arguments passed to the Python API.}
}
\value{
A reticulate-wrapped Python object, an R-converted Python result, or a scalar
value depending on the delegated Python function.
}
\details{
This package is intentionally named \pkg{survivalr} so it can coexist with
CRAN's \pkg{survival} package while the bridge matures. The Python package must
be installed in the Python environment selected by \pkg{reticulate}.
}
